{
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0"
  },
  "scripts": {
    "dev": "lsof -i:8000 >/dev/null 2>&1 && echo 'API already running on :8000' && pnpm run web:dev || concurrently -k -n api,web -c yellow,green \"cd ../TRR-Backend && source .venv/bin/activate && uvicorn api.main:app --reload --port 8000\" \"pnpm run web:dev\"",
    "dev:turbo": "pnpm run web:dev:turbo",
    "dev:web-only": "pnpm run web:dev",
    "dev:webpack": "pnpm run web:dev:webpack",
    "dev:stable": "pnpm run web:dev:stable",
    "emulators": "firebase emulators:start --import=.emulator-data --export-on-exit",
    "dev:local": "concurrently -k -n emu,web -c blue,green \"pnpm run emulators\" \"pnpm -C apps/web run dev:emu\"",
    "dev:local:3001": "concurrently -k -n emu,web -c blue,green \"pnpm run emulators\" \"PORT=3001 pnpm -C apps/web run dev:emu\"",
    "web:emu": "pnpm -C apps/web run dev:emu",
    "web:dev": "pnpm -C apps/web run dev",
    "web:dev:turbo": "pnpm -C apps/web run dev:turbo",
    "web:dev:webpack": "pnpm -C apps/web run dev:webpack",
    "web:dev:stable": "pnpm -C apps/web run dev:stable",
    "web:build": "pnpm -C apps/web run build",
    "web:start": "pnpm -C apps/web run start",
    "web:clean": "pnpm -C apps/web run clean",
    "web:vercel:version": "./scripts/vercel.sh --version",
    "web:vercel:build": "./scripts/vercel.sh build",
    "web:vercel:deploy": "./scripts/vercel.sh deploy",
    "wordle:dev": "pnpm -C apps/vue-wordle run dev",
    "wordle:build": "pnpm -C apps/vue-wordle run build",
    "wordle:preview": "pnpm -C apps/vue-wordle run preview"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1",
    "firebase-tools": "^15.13.0"
  },
  "pnpm": {
    "overrides": {
      "glob": "10.4.5",
      "json-ptr": "3.1.0",
      "node-domexception": "2.0.2"
    }
  },
  "engines": {
    "node": "24.x"
  }
}
