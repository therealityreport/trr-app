# TRR-APP setup adapter.
# Shared env ownership lives in ../../../docs/workspace/shared-env-manifest.json from the workspace root.
# Keep this file to app setup values; profiles/*.env own workspace runtime modes.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_ENABLE_APPLE=false
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
NEXT_PUBLIC_FIREBASE_EMULATOR_PROJECT_ID=demo-trr
NEXT_PUBLIC_REALITEASE_FEEDBACK_URL=
NEXT_PUBLIC_BRAVODLE_FEEDBACK_URL=
NEXT_PUBLIC_HOSTED_FONT_BASE_URL=https://pub-a3c452f3df0d40319f7c585253a4776c.r2.dev

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
# Local make dev direct lane. When present, this is preferred before session-pooler URLs.
TRR_DB_DIRECT_URL=
# Canonical runtime DB envs for server-side Postgres access.
# Default hosted runtime lane: Supavisor session mode on pooler.supabase.com:5432
TRR_DB_SESSION_URL=
TRR_DB_URL=
# Optional transaction-mode Supavisor URL on pooler.supabase.com:6543.
# Do not set TRR_DB_RUNTIME_LANE=transaction unless running a documented one-route flight test.
TRR_DB_TRANSACTION_URL=
TRR_DB_RUNTIME_LANE=session
TRR_DB_TRANSACTION_FLIGHT_TEST=0
# Optional operator-engaged break-glass fallback. Keep this on the same session-mode pooler lane (:5432).
# Runtime request handling does not auto-switch to this candidate on transient errors.
# To engage fallback, set TRR_DB_FORCE_FALLBACK=1 and restart or redeploy the app.
TRR_DB_FALLBACK_URL=
TRR_DB_FORCE_FALLBACK=
# App-side local defaults for the session pooler lane.
# In development, TRR uses a 1-slot app pool with 1 max concurrent operation by default.
POSTGRES_POOL_MAX=1
POSTGRES_MAX_CONCURRENT_OPERATIONS=1
POSTGRES_APPLICATION_NAME=trr-app:web

# ============================================================================
# Firebase Admin SDK Configuration (REQUIRED for API authentication)
# ============================================================================
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Paste the entire JSON object as a single-line string (minified, no line breaks)
FIREBASE_SERVICE_ACCOUNT=
# Auth provider adapter. Firebase is the only durable session issuer today.
# `supabase` remains diagnostics-only and durable login/session paths fail closed.
# Options: firebase | supabase
TRR_AUTH_PROVIDER=firebase
# When true, attempt secondary-provider verification for parity logging
TRR_AUTH_SHADOW_MODE=false
# Timeout for external auth fallbacks (Identity Toolkit and Supabase token shadow verification)
ADMIN_AUTH_EXTERNAL_TIMEOUT_MS=3000
# Optional Stage 3 cutover readiness thresholds (non-negative integers)
TRR_AUTH_CUTOVER_MIN_SHADOW_CHECKS=50
TRR_AUTH_CUTOVER_MAX_SHADOW_FAILURES=0
TRR_AUTH_CUTOVER_MAX_SHADOW_MISMATCH_EVENTS=0

# ============================================================================
# Admin Access Control
# ============================================================================
# Comma-separated list of admin email addresses (e.g., "admin@example.com,owner@example.com")
# Users with these emails can access /admin/survey-responses
ADMIN_EMAIL_ALLOWLIST=
# Alternative: public admin email list (less secure, visible to client)
NEXT_PUBLIC_ADMIN_EMAILS=
# Optional: additional admin UIDs (client-visible)
NEXT_PUBLIC_ADMIN_UIDS=
# Optional: case-sensitive display names that should receive admin access
ADMIN_DISPLAYNAME_ALLOWLIST=
# Client-exposed display names allowed in the admin UI (defaults include "The Reality Report Superfan @the_reality_report1")
NEXT_PUBLIC_ADMIN_DISPLAY_NAMES=
# Canonical admin origin. Use the clean Portless admin host for local browser work.
ADMIN_APP_ORIGIN=https://admin.trr.localhost
# Legacy-only compatibility switch for the classic portful admin fallback.
TRR_LEGACY_LOCAL_ADMIN_FALLBACK=0
# Optional production fallback when ADMIN_APP_ORIGIN is unset.
# ADMIN_APP_BASE_DOMAIN=thereality.report derives https://admin.thereality.report for server auth allowlists.
ADMIN_APP_BASE_DOMAIN=
# Optional request-host fallback when ADMIN_APP_ORIGIN is unset.
ADMIN_APP_DERIVE_FROM_REQUEST_HOST=false
# Optional admin host prefix for derived admin origins.
ADMIN_APP_HOST_PREFIX=admin
# Comma-separated hosts allowed for /api/admin/* (ADMIN_APP_ORIGIN host is also allowed).
# If unset in development, localhost-family API defaults are used.
ADMIN_APP_HOSTS=admin.trr.localhost,trr.localhost,localhost,127.0.0.1,[::1]
# Enforce host-based admin routing and API access gate (defaults to true when unset)
ADMIN_ENFORCE_HOST=true
# When true, admin host redirects non-admin page paths to /admin (never /api/*)
ADMIN_STRICT_HOST_ROUTING=false

# ============================================================================
# TRR Core API (Supabase) - Required for Admin Shows Hub
# ============================================================================
# Server-only Supabase admin/auth settings for show metadata reads and Supabase token verification.
TRR_CORE_SUPABASE_URL=https://vwxfvzutyufrkhfgoeaa.supabase.co
# Service role key (NOT anon key) - keep secret, server-side only
TRR_CORE_SUPABASE_SERVICE_ROLE_KEY=
# Shared secret used to mint short-lived internal admin bearer JWTs for backend proxy calls
TRR_INTERNAL_ADMIN_SHARED_SECRET=

# ============================================================================
# TRR Backend API - Required for Image Scraping
# ============================================================================
# URL to the TRR-Backend FastAPI server.
# Local dev example: http://127.0.0.1:8000
# Deployed example: https://<workspace>--trr-backend-api.modal.run
TRR_API_URL=http://127.0.0.1:8000
TRR_SOCIAL_PROXY_SHORT_TIMEOUT_MS=10000
TRR_SOCIAL_PROXY_DEFAULT_TIMEOUT_MS=25000
TRR_SOCIAL_PROXY_LONG_TIMEOUT_MS=60000
TRR_ADMIN_SOCIAL_PROFILE_SUMMARY_CACHE_TTL_MS=30000
TRR_REDDIT_CACHE_LOOKUP_TIMEOUT_MS=20000
TRR_REDDIT_CACHE_LOOKUP_RETRIES=1
# Reddit OAuth2 credentials (REQUIRED for reliable Reddit API access)
# Create a "script" app at https://www.reddit.com/prefs/apps
# The unauthenticated API is heavily rate-limited (~10 req/min vs 60 req/min with OAuth)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TRRAdminRedditDiscovery/1.0 (+https://thereality.report)
REDDIT_FETCH_TIMEOUT_MS=12000

# ============================================================================
# SSL overrides (optional – useful for self-signed certs)
# ============================================================================
# Force SSL on/off regardless of connection string sslmode (values: "true"/"false"/"require"/"disable")
DATABASE_SSL=
# Override TLS certificate verification ("false" allows self-signed certs)
DATABASE_SSL_REJECT_UNAUTHORIZED=
# Inline CA bundle (multi-line string or \n separated)
DATABASE_SSL_CA=
# Or provide a relative path to a PEM file (e.g., apps/web/certs/us-east-1-bundle.pem)
DATABASE_SSL_CA_FILE=

# ============================================================================
# Sentry Error Monitoring (OPTIONAL - fully env-gated, OFF when DSN is unset)
# ============================================================================
# Leave SENTRY_DSN and NEXT_PUBLIC_SENTRY_DSN blank to keep Sentry a complete
# no-op: no init, no build plugin, no source map upload, build/runtime unchanged.
#
# Server + edge runtime DSN (server-only; not exposed to the browser).
SENTRY_DSN=
# Browser DSN (must be NEXT_PUBLIC_* to be readable in client init).
NEXT_PUBLIC_SENTRY_DSN=
# Environment tag for Sentry events. Falls back to APP_ENV then NODE_ENV.
# (Client init reads NEXT_PUBLIC_TRR_ENV, then TRR_ENV, then NODE_ENV.)
TRR_ENV=
# Performance tracing sample rate 0..1. Default 0 (errors only, no tracing).
SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Optional source-map upload credentials. Upload is skipped unless ALL three of
# SENTRY_AUTH_TOKEN + SENTRY_ORG + SENTRY_PROJECT are set. The build never fails
# when these are absent.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Optional verbose Sentry SDK logging (set to "true" to enable).
SENTRY_DEBUG=
NEXT_PUBLIC_SENTRY_DEBUG=

# Getty Scraper (Cloudflare Tunnel)
# ============================================================================
# URL of the Getty local scraper. Default: http://127.0.0.1:3456
# Set to https://scraper.thereality.report when running behind Cloudflare Tunnel.
TRR_GETTY_LOCAL_URL=
# Shared secret to authenticate requests to the Getty scraper behind the tunnel.
# Must match TRR_GETTY_SCRAPER_SECRET on the server side. Leave blank for local dev.
TRR_GETTY_SCRAPER_SECRET=
