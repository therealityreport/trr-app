{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:turbo": "next dev --turbopack",
    "dev:webpack": "next dev --webpack",
    "dev:stable": "next dev --webpack",
    "dev:emu": "NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true next dev --turbopack -p ${PORT:-3000}",
    "dev:emu:stable": "NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true next dev --webpack -p ${PORT:-3000}",
    "build": "next build --webpack",
    "build:turbo": "next build --turbopack",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "typecheck:fandom": "tsc -p tsconfig.typecheck.fandom.json --noEmit",
    "lint": "eslint",
    "clean": "rm -rf .next",
    "generate:brand-font-artifacts": "node scripts/generate-brand-font-artifacts.mjs",
    "generate:brand-font-artifacts:with-glyphs": "node scripts/generate-brand-font-artifacts.mjs --with-glyph-comparison",
    "brand-fonts:visual-similarity": "node scripts/brand-font-visual-similarity.mjs",
    "brand-fonts:glyph-comparison": "node scripts/brand-font-glyph-comparison.mjs",
    "design-docs:classify": "node scripts/design-docs/classify-publisher-patterns.mjs",
    "design-docs:extract-navigation": "node scripts/design-docs/extract-navigation.mjs",
    "design-docs:nyt-games:media": "node scripts/design-docs/generate-nyt-games-media-artifacts.mjs",
    "design-docs:nyt-games:media:validate": "node scripts/design-docs/validate-nyt-games-media.mjs",
    "design-docs:validate-config": "node scripts/design-docs/validate-config-integrity.mjs",
    "design-docs:a11y-audit": "node scripts/design-docs/run-accessibility-audit.mjs",
    "design-docs:integration-checks": "node scripts/design-docs/run-integration-checks.mjs",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "test:ci": "node scripts/test-ci.mjs",
    "smoke:cast:preflight": "node scripts/cast-smoke-preflight.mjs",
    "smoke:cast:preflight:auth": "node scripts/cast-smoke-preflight.mjs --cookie-file \"${TRR_CAST_SMOKE_COOKIE_FILE:-}\"",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:cast": "playwright test -c playwright.config.ts tests/e2e/admin-cast-tabs-smoke.spec.ts",
    "test:e2e:cast:live": "E2E_CAST_LIVE=1 playwright test -c playwright.config.ts tests/e2e/admin-cast-tabs-live-smoke.spec.ts",
    "test:e2e:headed": "playwright test -c playwright.config.ts --headed",
    "db:migrate": "node ./scripts/run-migrations.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@firebase/app": "0.14.9",
    "@firebase/component": "0.7.1",
    "@firebase/firestore": "4.9.0",
    "@firebase/logger": "0.5.0",
    "@firebase/util": "1.14.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/functions": "^3.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^12.7.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "pg": "^8.19.0",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "undici": "^7.24.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.11.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9",
    "vitest-axe": "^0.1.0"
  },
  "engines": {
    "node": "24.x"
  }
}
