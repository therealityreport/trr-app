rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isIsoDate(value) {
      return value is string
        && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidGame(value) {
      return value is string
        && (value == "bravodle" || value == "realitease");
    }

    function isValidProblemCategory(value) {
      return value is string
        && (
          value == "technical"
          || value == "incorrect-info"
          || value == "accessibility"
          || value == "content"
          || value == "other"
        );
    }

    // User-scoped analytics + game docs
    match /user_analytics/{userId} {
      allow read, write: if isOwner(userId);

      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Public roster metadata (read-only)
    match /realitease_talent/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Puzzle/global analytics are readable by all clients.
    // Writes are limited to authenticated sessions.
    match /realitease_analytics/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /bravodle_analytics/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Answer keys are never writable by clients.
    // Read requires authentication.
    match /realitease_answerkey/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /bravodle_answerkey/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Problem reports can only be created by the authenticated user.
    match /problem_reports/{docId} {
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly([
          "userId",
          "game",
          "puzzleDate",
          "category",
          "description"
        ])
        && request.resource.data.userId is string
        && request.resource.data.userId == request.auth.uid
        && isValidGame(request.resource.data.game)
        && isIsoDate(request.resource.data.puzzleDate)
        && isValidProblemCategory(request.resource.data.category)
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 2000;
      allow read, update, delete: if false;
    }

    // Deny all other access by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
